#include <SPI.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#include "bitmap.h" 

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

#define OLED_RESET     -1 
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);


void bootOS() {
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(0, 0);
  
  display.println("ROM BI0S (C) 1996"); delay(500); display.display();
  display.println("RAM OK.. 640KB"); delay(400); display.display();
  display.println("LOADING KASH_OS_v1.0"); delay(600); display.display();
  display.println("DRIVES READY..."); delay(500); display.display();
  display.println("BOOTING SUCCESSFUL."); delay(800); display.display();
  
  delay(1000);
}


void showThinkingAnimation() {
 
  for(int loopCount = 0; loopCount < 6; loopCount++) {
    display.clearDisplay();
    display.setCursor(0, 20);
    display.setTextSize(2); // ටිකක් ලොකුවට පේන්න
    display.print("Thinking"); display.display(); delay(400);
    display.print("."); display.display(); delay(400);
    display.print("."); display.display(); delay(400);
    display.print("."); display.display(); delay(400);
  }
}


void typeText(String message, int speedDelay) {
  for (int i = 0; i < message.length(); i++) {
    display.print(message[i]);
    display.display();
    delay(speedDelay);
  }
}


